# Upstash Redis — get these from the Upstash console or the Vercel Marketplace integration.
# The app also accepts Vercel's KV_REST_API_* naming automatically.
#
# Without these set, the app falls back to in-memory storage (fine for local dev,
# but every report is lost when the server restarts — do NOT rely on it in production).

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
